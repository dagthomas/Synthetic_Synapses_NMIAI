# Astar Island Solution — Environment Variables
# Copy to .env and fill in your values

# Required: JWT token for Astar Island API (https://app.ainm.no)
ASTAR_TOKEN=your_jwt_token_here

# Required for AI researchers: Google Gemini API key
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Alternative Gemini key (fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: GCP settings (for cloud GPU training)
GCP_PROJECT_ID=your_project_id
GCP_LOCATION=us-central1
