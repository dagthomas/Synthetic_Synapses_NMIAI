      "id": "review::.::holistic::error_consistency::silent-exception-swallowing::406a4a26",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Multiple bare 'except Exception:' or 'except:' blocks that silently swallow errors with only a pass or minimal logging, masking potential failures",
