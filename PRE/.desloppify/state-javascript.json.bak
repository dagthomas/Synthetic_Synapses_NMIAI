    "review::.::holistic::type_safety::no-type-annotations-on-public-functions::b2594644": {
      "id": "review::.::holistic::type_safety::no-type-annotations-on-public-functions::b2594644",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "Only 8 out of ~247 top-level function definitions across 63 Python files have return type annotations. The sole typed module is solution_store.py. Core solver functions like GPUBeamSearcher.__init__, dp_search, _step, _eval, and all functions in game_engine.py, precompute.py, live_gpu_stream.py, replay_solution.py, and every planner variant lack any type annotations on parameters or return values.",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "grocery-bot-gpu/gpu_beam_search.py",
          "grocery-bot-gpu/gpu_sequential_solver.py",
          "grocery-bot-gpu/game_engine.py",
          "grocery-bot-gpu/precompute.py",
          "grocery-bot-gpu/live_gpu_stream.py",
          "grocery-bot-gpu/replay_solution.py",
          "grocery-bot-gpu/planner.py"
        ],
        "evidence": [
          "grep for 'def \\w+(.*) -> ' across grocery-bot-gpu/*.py returns only 8 matches, all in solution_store.py",
          "gpu_beam_search.py __init__ takes 10+ parameters with no type annotations",
          "game_engine.py: step(), init_game(), build_map(), build_map_from_capture() all untyped",
          "precompute.py: PrecomputedTables.get(), _compute(), to_gpu_tensors() all untyped",
          "gpu_sequential_solver.py: solve_sequential has docstring types but no annotations on the function signature beyond the SolveConfig/SolveCallbacks dataclasses"
        ],
        "suggestion": "Add type annotations to at minimum the public API functions: solve_sequential, refine_from_solution, cpu_verify, init_game, init_game_from_capture, step, build_map_from_capture, PrecomputedTables.get, and GPUBeamSearcher.__init__/dp_search. Even partial typing on the 15-20 most-imported functions would catch misuse at call sites.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-04T21:29:16+00:00",
      "last_seen": "2026-03-04T21:29:16+00:00",
      "resolved_at": "2026-03-04T21:56:50+00:00",
      "reopen_count": 0,
      "lang": "javascript",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::type_safety::untyped-dict-interchange-format::14e0a4e4": {
      "id": "review::.::holistic::type_safety::untyped-dict-interchange-format::14e0a4e4",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "high",
      "summary": "The capture_data dict is the primary interchange format across 15+ modules (solution_store, gpu_sequential_solver, live_gpu_stream, replay_solution, capture_and_solve_stream, iterate_local, optimize_and_save, etc.) but CaptureData TypedDict in game_engine.py is never enforced at boundaries. Functions accept Dict[str, Any] or bare dict, making it easy to pass malformed data.",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "grocery-bot-gpu/game_engine.py",
          "grocery-bot-gpu/solution_store.py",
          "grocery-bot-gpu/gpu_sequential_solver.py",
          "grocery-bot-gpu/live_gpu_stream.py",
          "grocery-bot-gpu/iterate_local.py"
        ],
        "evidence": [
          "game_engine.py defines CaptureData(TypedDict) at line 18 but no function signature uses it",
          "solution_store.py: save_capture takes capture_data: Dict[str, Any], not CaptureData",
          "gpu_sequential_solver.py: solve_sequential takes capture_data with no type annotation at all",
          "iterate_local.py: make_capture_from_seed returns a plain dict, not validated against CaptureData"
        ],
        "suggestion": "Use CaptureData as the parameter type for functions that accept capture data. At minimum, annotate the top-level solve_sequential, save_capture, merge_capture, and init_game_from_capture signatures with CaptureData.",
        "reasoning": ""
      },
      "status": "auto_resolved",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-04T21:29:16+00:00",
      "last_seen": "2026-03-04T21:29:16+00:00",
      "resolved_at": "2026-03-04T21:56:50+00:00",
      "reopen_count": 0,
      "lang": "javascript",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::contract_coherence::error-contract-not-enforced-by-types::fd34dc54": {
      "id": "review::.::holistic::contract_coherence::error-contract-not-enforced-by-types::fd34dc54",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "medium",
      "summary": "gpu_sequential_solver.py documents error contracts in module docstring (returns (0, []) on failure, raises ValueError on invalid input) but these contracts are not enforced by type annotations or runtime checks at all call sites. Callers like optimize_and_save.py, live_gpu_stream.py, and production_run.py do not consistently check for the (0, []) failure return before using results.",
      "detail": {
        "holistic": true,
        "dimension": "contract_coherence",
        "related_files": [
          "grocery-bot-gpu/gpu_sequential_solver.py",
          "grocery-bot-gpu/optimize_and_save.py",
          "grocery-bot-gpu/live_gpu_stream.py",
          "grocery-bot-gpu/production_run.py"
        ],
        "evidence": [
          "gpu_sequential_solver.py docstring says: 'Returns (0, []) if GPU/CPU verification fails. Callers should check score > 0 before using the actions.'",
          "optimize_and_save.py calls solve_sequential but wraps in a bare try/except, does not explicitly check for score==0 failure return",
          "live_gpu_stream.py _gpu_worker catches Exception broadly and logs it, but does not distinguish (0,[]) solver failure from other errors"
        ],
